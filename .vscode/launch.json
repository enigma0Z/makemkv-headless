{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Python: Current File",
      "type": "debugpy",
      "request": "launch",
      "program": "${file}",
      "console": "integratedTerminal"
    },
    {
      "name": "Debug API",
      "type": "debugpy",
      "request": "launch",
      "module": "makemkv_headless.__main__",
      "cwd": "${workspaceFolder}/api",
      "args": ["start", "--config-file", "local.config.yaml"],
      "console": "integratedTerminal"
    },
    {
      "type": "node-terminal",
      "name": "Launch Web",
      "request": "launch",
      "command": "npm run dev",
      "cwd": "${workspaceFolder}/web"
    }
  ]
}