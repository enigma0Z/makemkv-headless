{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "API",
      "type": "debugpy",
      "request": "launch",
      "module": "makemkv_headless.__main__",
      "cwd": "${workspaceFolder}/api",
      "args": ["start", "--config-file", "local.config.yaml"],
      "console": "integratedTerminal"
    },
    {
      "type": "node-terminal",
      "name": "Web",
      "request": "launch",
      "command": "npm run dev",
      "cwd": "${workspaceFolder}/web"
    }
  ],
  "compounds": [
    {
      "name": "API + Web",
      "configurations": ["API", "Web"],
      "stopAll": true
    }
  ]
}